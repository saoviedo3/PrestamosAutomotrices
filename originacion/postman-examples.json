        "email": "juan.perez@email.com",
        "telefono": "0987654321",
        "direccion": "Av. Principal 123, Quito",
        "ingresos": 2500.00,
        "egresos": 1200.00
      }
    },
    
    "2_crear_solicitud_credito": {

        "buscar_por_nombre": "GET {{base_url}}/api/clientes-prospectos/buscar?termino=Juan",
        "capacidad_pago": "GET {{base_url}}/api/clientes-prospectos/1/capacidad-pago",
        "simular_credito": "POST {{base_url}}/api/clientes-prospectos/1/simular-credito?monto=25000&tasa=12.5&plazo=60",
